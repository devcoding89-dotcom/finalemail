{
  "manifest_version": 3,
  "name": "Auto Scout - EmailSend Extension",
  "version": "1.0",
  "description": "Fully automated email sending sequence for EmailSend SaaS.",
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:3000/*",
    "https://*.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Auto Scout"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:3000/*", "https://*.vercel.app/*"],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_start"
    }
  ]
}
